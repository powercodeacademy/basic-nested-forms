source 'https://rubygems.org'

# Ruby and Rails
ruby '3.3.5'
gem 'rails', '~> 7.1.0'
gem 'sqlite3', '~> 1.6'

# Web server
gem 'puma', '~> 6.0'
gem 'webrick', '~> 1.8'

# JavaScript and CSS (Rails 7 uses import maps or jsbundling-rails, but keep jquery-rails for legacy)
gem 'jbuilder', '~> 2.0'
gem 'jquery-rails'
gem 'turbolinks', '~> 5.2'

# Misc
gem 'ostruct'

# RSpec for testing
group :development, :test do
  gem 'byebug'
  gem 'pry'
  gem 'rspec-rails', '~> 6.0'
end

group :development do
  gem 'rubocop', '~> 1.53.0'
end

# Docs
group :doc do
  gem 'sdoc'
end
